# Solana Configuration
# Get free RPC endpoint from: https://www.helius.dev/ or https://www.quicknode.com/
SOLANA_RPC_ENDPOINT=https://api.mainnet-beta.solana.com

# Ethereum Configuration
# Get API key from: https://www.alchemy.com/ or https://infura.io/
ETHEREUM_RPC_ENDPOINT=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ALCHEMY_API_KEY=your_alchemy_api_key_here

# CoinGecko API (for historical pricing)
# Free tier: 10-30 calls/minute
# Get API key from: https://www.coingecko.com/en/api/pricing
# Leave empty to use free tier (rate limited)
COINGECKO_API_KEY=

# Alternative: CryptoCompare API
# CRYPTOCOMPARE_API_KEY=

# Application Settings
NEXT_PUBLIC_APP_NAME=Crypto Tax Reporter
NEXT_PUBLIC_MAX_WALLETS=10

# Optional: Sentry for error tracking
# SENTRY_DSN=

# Optional: Analytics
# NEXT_PUBLIC_GA_TRACKING_ID=

# Supabase Configuration (for user authentication and data storage)
# Get from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# NextAuth Configuration (for authentication)
NEXTAUTH_URL=http://localhost:3002
NEXTAUTH_SECRET=generate-a-random-secret-key-here
